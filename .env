# ============================================================
# ZTP Server Configuration
# Edit this file to match your network environment.
# All other files (dnsmasq, docker-compose) read from here.
# ============================================================

# IP address of this laptop on the switch-facing interface
SERVER_IP=192.168.100.1

# HTTP port for the ZTP web server
HTTP_PORT=8080

# DNS servers handed out to switches via DHCP
DNS_SERVER=1.1.1.1,8.8.8.8

# DHCP pool assigned to switches
DHCP_RANGE_START=192.168.100.20
DHCP_RANGE_END=192.168.100.100
DHCP_SUBNET=255.255.255.0
DHCP_LEASE=1h

# Network interface facing the switches
# Leave blank to auto-detect (first non-loopback UP interface)
INTERFACE=enp2s0

# Default config file for unknown/unregistered switches
DEFAULT_CONFIG=generic.cfg

# Max seconds a higher-priority switch waits for lower-priority
# switches to complete before being released anyway (default 30 min)
PRIORITY_WAIT_TIMEOUT=1800

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO